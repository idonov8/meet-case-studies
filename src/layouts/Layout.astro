---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "meet — Case Study Deliverables",
  description = "An interactive workspace for MEET case-study teams to draft, structure, and track every deliverable across the four-day sprint.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      meet's brand face is Proxima Nova (licensed). If you have an Adobe Fonts/Typekit
      kit, drop its <link> here and the CSS stack will use it automatically. Montserrat is
      loaded below as the free fallback so the app looks right without the kit.
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
